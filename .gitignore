# Dependencies
node_modules/

# Environment (no versionar secretos ni overrides locales)
.env
.env.*
!.env.example

# Build / Next.js
.next/
frontend/.next/
out/
dist/
build/
*.tsbuildinfo

# Monorepo: un solo lockfile en la raíz
frontend/bun.lock

# Debug / OS
.DS_Store
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/*
!.vscode/extensions.json

# Bun
.bun/

# Deploy / CI local
.vercel/

# Credenciales y claves sueltas (evitar commits accidentales)
*.pem
*.p12
*.key
service-account*.json
credentials.json
google-services.json

# Herramientas y artefactos de prueba
.turbo/
coverage/
playwright-report/
test-results/
*.lcov

# PDF del UI Kit (referencia en Google Drive; no versionar)
docs/uikit_gob/*.pdf

# RAG — base de datos vectorial generada al ingestar (no versionar)
rag/chroma_db/

# Documentos normativos — PDFs institucionales (solo local y servidor TI; nunca al repo)
documentos/